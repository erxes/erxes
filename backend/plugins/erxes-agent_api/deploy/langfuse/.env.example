# Central Langfuse v3 server config — copy to .env and CHANGE every secret.
# Generate:  openssl rand -hex 32   (ENCRYPTION_KEY — must be 64 hex chars)
#            openssl rand -base64 32 (SALT, NEXTAUTH_SECRET)

# ── App (always required) ──────────────────────────────────────────────────
LANGFUSE_PUBLIC_URL=https://langfuse.your-domain.com   # public URL of the UI
LANGFUSE_PORT=3000                                      # host port for langfuse-web
LANGFUSE_SALT=CHANGE_ME
LANGFUSE_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
LANGFUSE_NEXTAUTH_SECRET=CHANGE_ME

# ── First-boot admin (3 vars) — seeds login so sign-up stays OFF ────────────
# Langfuse can't seed a user without an org; the admin creates the project +
# API keys after logging in. ORG_ID is any stable slug. Omit this whole block
# to instead create the first account via UI (set LANGFUSE_DISABLE_SIGNUP=false
# for that one boot). Sign-up is disabled by default either way.
LANGFUSE_INIT_ORG_ID=erxes
LANGFUSE_INIT_USER_EMAIL=admin@your-domain.com
LANGFUSE_INIT_USER_PASSWORD=CHANGE_ME_strong_password
# LANGFUSE_DISABLE_SIGNUP=true   # default; only set =false for a UI-signup boot

# ── Backing stores: full connection strings — point anywhere ────────────────
# Production: set these to your MANAGED services (RDS / Clickhouse Cloud /
# Elasticache / S3) and deploy with just `docker compose up -d`.
LANGFUSE_DATABASE_URL=postgresql://user:pass@your-postgres-host:5432/langfuse
LANGFUSE_CLICKHOUSE_URL=https://your-clickhouse-host:8443
LANGFUSE_CLICKHOUSE_MIGRATION_URL=clickhouse://your-clickhouse-host:9440
LANGFUSE_CLICKHOUSE_USER=default
LANGFUSE_CLICKHOUSE_PASSWORD=CHANGE_ME
LANGFUSE_REDIS_URL=redis://:CHANGE_ME@your-redis-host:6379
LANGFUSE_S3_ENDPOINT=https://s3.your-region.amazonaws.com
LANGFUSE_S3_BUCKET=langfuse
LANGFUSE_S3_REGION=your-region
LANGFUSE_S3_ACCESS_KEY=CHANGE_ME
LANGFUSE_S3_SECRET_KEY=CHANGE_ME
LANGFUSE_S3_FORCE_PATH_STYLE=false   # true for MinIO / path-style S3

# ── ALTERNATIVE: all-in-one box with the bundled stores ─────────────────────
# Use these values INSTEAD of the managed block above, then start with:
#   docker compose --profile bundled-stores up -d
# (service names match the bundled containers; set the bundled passwords too.)
#
# LANGFUSE_DATABASE_URL=postgresql://postgres:CHANGE_ME@langfuse-postgres:5432/postgres
# LANGFUSE_CLICKHOUSE_URL=http://langfuse-clickhouse:8123
# LANGFUSE_CLICKHOUSE_MIGRATION_URL=clickhouse://langfuse-clickhouse:9000
# LANGFUSE_CLICKHOUSE_PASSWORD=CHANGE_ME
# LANGFUSE_REDIS_URL=redis://:CHANGE_ME@langfuse-redis:6379
# LANGFUSE_S3_ENDPOINT=http://langfuse-minio:9000
# LANGFUSE_S3_ACCESS_KEY=minio
# LANGFUSE_S3_SECRET_KEY=CHANGE_ME
# LANGFUSE_S3_FORCE_PATH_STYLE=true
# # bundled-store passwords — required by the profile, keep in sync with the URLs:
# LANGFUSE_BUNDLED_POSTGRES_PASSWORD=CHANGE_ME
# LANGFUSE_BUNDLED_REDIS_PASSWORD=CHANGE_ME
