{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/modules/*"]
    },
    "types": ["node"]
  },
  "exclude": ["node_modules", "dist", "scripts/**", "**/*spec.ts", "**/*.test.ts", "**/__tests__/**", "src/studio/**", "src/mastra/index.ts"]
}
