# REACT_APP_API_URL=http://localhost:4000
# NODE_ENV=development
# MONGO_URL=mongodb://localhost:27017/erxes
# NODE_OPTIONS=--max-old-space-size=1536
# ENABLED_PLUGINS=operation
# DISABLE_CHANGE_STREAM=true
# --- Sentry: backend API services (environment e.g. production-api / amaraa-test-local) ---
# SENTRY_DSN=api_sentry_dsn
# SENTRY_ENVIRONMENT=api_sentry_environment_name
# SENTRY_TRACES_SAMPLE_RATE=0.1
# --- Sentry: frontend (core-ui host + MF remotes). In prod, docker-entrypoint.sh
#     injects any REACT_APP_* var into window.env at container start. ---
# REACT_APP_SENTRY_DSN=ui_sentry_dsn
# REACT_APP_SENTRY_ENVIRONMENT=ui_sentry_environment_name
# RELEASE_VERSION=erxes-<git-sha-or-version>

# --- Mastra AI Plugin ---
# Erxes API connection (overrides the value stored in Settings UI)
# MASTRA_ERXES_API_URL=http://localhost:4000
# MASTRA_ERXES_API_TOKEN=

# Default agent ID for the bot webhook endpoint
# MASTRA_DEFAULT_AGENT_ID=

# LibSQL memory database path
# MASTRA_MEMORY_DB_PATH=file:./mastra-memory.db

# Provider API keys (each overrides the key stored in Provider UI)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# CO_API_KEY=
# MOONSHOT_API_KEY=
# NVIDIA_API_KEY=

# --- erxes-agent: shared Qdrant + embedder (used by advanced memory AND company knowledge) ---
# Qdrant: docker compose -f backend/plugins/erxes-agent_api/docker-compose.yml up -d
# ERXES_AGENT_QDRANT_URL=http://localhost:6333
# ERXES_AGENT_QDRANT_API_KEY=
# ERXES_AGENT_EMBEDDER=fastembed            # fastembed (local, default) or openai
# ERXES_AGENT_EMBEDDER_MODEL=bge-small-en-v1.5
# ERXES_AGENT_EMBEDDER_BASE_URL=https://api.openai.com/v1
# ERXES_AGENT_EMBEDDER_API_KEY=

# --- erxes-agent: advanced memory (semantic recall + working memory) ---
# ERXES_AGENT_MEMORY=enable                 # exactly "enable" turns it on
# ERXES_AGENT_MEMORY_TOPK=4
# ERXES_AGENT_MEMORY_MIN_SCORE=0.5
# ERXES_AGENT_MEMORY_SCOPE=resource         # resource or thread

# --- erxes-agent: company knowledge RAG ---
# See backend/plugins/erxes-agent_api/docs/COMPANY_KNOWLEDGE_RAG.md
# ERXES_AGENT_KNOWLEDGE=enable              # exactly "enable" turns it on
# Which content types get embedded. Default: kb-article only (published+public).
# Adding PII-bearing types (customer, conversation, deal, ...) is a deliberate
# data-residency decision — with ERXES_AGENT_EMBEDDER=openai their text leaves
# the deployment at embed time. Available:
#   kb-article, customer, company, product, deal, task, conversation
# ERXES_AGENT_KNOWLEDGE_TYPES=kb-article
# ERXES_AGENT_KNOWLEDGE_MAX_PER_TYPE=0      # per-type record cap per sweep (0 = unlimited)
# ERXES_AGENT_KNOWLEDGE_TOPK=4
# ERXES_AGENT_KNOWLEDGE_MIN_SCORE=0.5
# ERXES_AGENT_KNOWLEDGE_OVERFETCH=3         # candidate multiplier for the live post-filter
# ERXES_AGENT_KNOWLEDGE_SYNC_CRON=0 * * * * # reconciliation sweep schedule (UTC)
